{
  "name": "kubernetes-job-monitoring",
  "private": true,
  "workspaces": [
    "api-gateway",
    "worker",
    "stats-aggregator"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "dotenv": "^16.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "husky": "^9.1.7"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx}": [
      "prettier --write",
      "eslint ."
    ],
    "**/*.json": [
      "prettier --write"
    ],
    "**/*.md": [
      "prettier --write"
    ]
  }
}
